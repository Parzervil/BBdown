<UserControl x:Class="BBDown.GUI.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="White"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,8,0"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="解析结果"
                               FontWeight="SemiBold"
                               FontSize="16"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="全选"
                                Command="{Binding SelectAllPagesCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" />
                        <Button Content="反选"
                                Command="{Binding InvertPageSelectionCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" />
                        <Button Content="仅最新"
                                Command="{Binding SelectLatestPageCommand}"
                                Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="{Binding VideoTitle}"
                               AutomationProperties.AutomationId="VideoTitleTextBlock"
                               FontWeight="Bold"
                               FontSize="15"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding VideoInfo}"
                               Foreground="#FF666666"
                               Margin="0,4,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="勾选结果会在下载时转换为分P参数；未解析时可使用右侧手动输入。"
                           Foreground="#FF777777"
                           FontSize="12"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap" />

                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding Pages}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="选"
                                                Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                Width="54" />
                        <DataGridTextColumn Header="P" Binding="{Binding Index}" Width="48" IsReadOnly="True" />
                        <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
                        <DataGridTextColumn Header="时长" Binding="{Binding Duration}" Width="90" IsReadOnly="True" />
                        <DataGridTextColumn Header="AID" Binding="{Binding Aid}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="CID" Binding="{Binding Cid}" Width="120" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="8,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="16"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="快速设置"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,12" />

                    <TextBlock Text="解析接口" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <WrapPanel>
                        <CheckBox Content="TV" IsChecked="{Binding UseTvApi}" Margin="0,0,12,4" />
                        <CheckBox Content="APP" IsChecked="{Binding UseAppApi}" Margin="0,0,12,4" />
                        <CheckBox Content="国际版" IsChecked="{Binding UseIntlApi}" Margin="0,0,0,4" />
                    </WrapPanel>

                    <TextBlock Text="输出目录" FontWeight="SemiBold" Margin="0,12,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding OutputDir, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Content="浏览"
                                Command="{Binding BrowseOutputCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <TextBlock Text="分P选择" FontWeight="SemiBold" Margin="0,12,0,8" />
                    <TextBox Text="{Binding SelectPage, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="例如: 1,2 或 3-5 或 ALL" />

                    <TextBlock Text="下载选项" FontWeight="SemiBold" Margin="0,12,0,8" />
                    <WrapPanel>
                        <CheckBox Content="下载弹幕" IsChecked="{Binding DownloadDanmaku}" Margin="0,0,12,4" />
                        <CheckBox Content="跳过字幕" IsChecked="{Binding SkipSubtitle}" Margin="0,0,12,4" />
                        <CheckBox Content="跳过封面" IsChecked="{Binding SkipCover}" Margin="0,0,12,4" />
                        <CheckBox Content="仅音频" IsChecked="{Binding AudioOnly}" Margin="0,0,12,4" />
                        <CheckBox Content="仅视频" IsChecked="{Binding VideoOnly}" Margin="0,0,12,4" />
                        <CheckBox Content="跳过混流" IsChecked="{Binding SkipMux}" Margin="0,0,12,4" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="8"
                    Padding="16"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="流选择"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,8" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding Stream.StatusText}"
                               Foreground="#FF666666"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <GroupBox Grid.Row="2" Header="视频流" Margin="0,0,0,8">
                        <DataGrid ItemsSource="{Binding Stream.VideoStreams}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="清晰度" Binding="{Binding Dfn}" Width="*" />
                                <DataGridTextColumn Header="分辨率" Binding="{Binding Resolution}" Width="90" />
                                <DataGridTextColumn Header="编码" Binding="{Binding Codecs}" Width="70" />
                                <DataGridTextColumn Header="FPS" Binding="{Binding Fps}" Width="56" />
                                <DataGridTextColumn Header="码率" Binding="{Binding Bandwidth}" Width="90" />
                                <DataGridTextColumn Header="大小" Binding="{Binding Size}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Row="3" Header="音频流">
                        <DataGrid ItemsSource="{Binding Stream.AudioStreams}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="*" />
                                <DataGridTextColumn Header="编码" Binding="{Binding Codecs}" Width="80" />
                                <DataGridTextColumn Header="码率" Binding="{Binding Bandwidth}" Width="100" />
                                <DataGridTextColumn Header="估算大小" Binding="{Binding Size}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
