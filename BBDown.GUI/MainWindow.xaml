<Window x:Class="BBDown.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:BBDown.GUI.Views"
        mc:Ignorable="d"
        Title="BBDown GUI"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F5">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#FF00A1D6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF0087B3" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFCCCCCC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#FF333333" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderBrush" Value="#FFDDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF0F0F0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FF333333" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEFF7FB" />
                    <Setter Property="Foreground" Value="#FF0087B3" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#FFDDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#FFDDDDDD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                    <TextBlock Text="BBDown"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FF00A1D6"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentPageTitle}"
                               FontSize="14"
                               Foreground="#FF666666"
                               VerticalAlignment="Center"
                               Margin="12,4,0,0" />
                </StackPanel>

                <TextBox Grid.Column="1"
                         AutomationProperties.AutomationId="UrlTextBox"
                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         ToolTip="输入视频地址或 av|bv|ep|ss" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button Content="解析"
                            AutomationProperties.AutomationId="ParseButton"
                            Command="{Binding ParseCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" />
                    <Button Content="下载"
                            AutomationProperties.AutomationId="DownloadButton"
                            Command="{Binding DownloadCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="168" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,12,0"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1">
                <StackPanel>
                    <Button Content="下载"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Download"
                            Style="{StaticResource NavButton}" />
                    <Button Content="任务"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Tasks"
                            Style="{StaticResource NavButton}"
                            Margin="0,4,0,0" />
                    <Button Content="历史"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="History"
                            Style="{StaticResource NavButton}"
                            Margin="0,4,0,0" />
                    <Button Content="设置"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Settings"
                            Style="{StaticResource NavButton}"
                            Margin="0,4,0,0" />
                    <Button Content="登录"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Login"
                            Style="{StaticResource NavButton}"
                            Margin="0,4,0,0" />
                    <Button Content="服务"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="Service"
                            Style="{StaticResource NavButton}"
                            Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <views:DownloadView Visibility="{Binding IsDownloadPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <views:TaskQueueView Visibility="{Binding IsTasksPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <views:HistoryView Visibility="{Binding IsHistoryPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <views:SettingsView Visibility="{Binding IsSettingsPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <views:LoginView Visibility="{Binding IsLoginPage, Converter={StaticResource BoolToVisibilityConverter}}" />
                <views:ServiceView Visibility="{Binding IsServicePage, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="14"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="运行日志"
                               FontWeight="SemiBold"
                               FontSize="14" />
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="清空"
                            Command="{Binding ClearLogCommand}"
                            Style="{StaticResource SecondaryButton}" />

                    <ListBox Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Margin="0,10,0,0"
                             BorderThickness="0"
                             ItemsSource="{Binding Logs}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Consolas"
                             FontSize="12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,12,0,0"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding ProgressText}" Margin="0,0,0,8" />
                    <ProgressBar Grid.Row="1"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue}"
                                 Foreground="#FF00A1D6"
                                 Background="#FFE8E8E8"
                                 BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
